{
    "printWidth": 100,
    "semi": false,
    "tabWidth": 4,
    "phpVersion": "8.4",
    "plugins": ["prettier-plugin-blade", "@prettier/plugin-php"],
    "overrides": [
        {
            "files": ["*.blade.php"],
            "options": {
                "parser": "blade"
            }
        },
        {
            "files": "**/*.yml",
            "options": {
                "tabWidth": 2
            }
        }
    ]
}
